#!/usr/bin/env bash
# Regenerate the README hero screenshot when staged changes could affect
# the rendered UI. Skips entirely when nothing under Sources/ is staged
# so non-UI commits (docs, CI, scripts) don't pay the cost.
set -euo pipefail

# Bypass via `git commit --no-verify`.
staged_sources=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^Sources/' || true)
if [ -z "$staged_sources" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "pre-commit: regenerating screenshots/*.png"
swift run --quiet Screenshot >/dev/null

# Only stage PNGs whose content actually changed. Identical re-renders
# are a no-op — keeps the commit lean and history small.
changed=$(git diff --name-only -- 'screenshots/*.png' 2>/dev/null || true)
if [ -n "$changed" ]; then
  echo "$changed" | xargs git add
  echo "pre-commit: staged updated screenshot(s):"
  echo "$changed" | sed 's/^/  /'
fi
